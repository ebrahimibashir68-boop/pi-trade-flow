{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "pitrade-mcp",
      "version": "0.1.0",
      "title": "PiTrade MCP"
    },
    "tools": [
      {
        "name": "draft_contract_outline",
        "title": "Draft Pi-settled trade contract outline",
        "description": "Produce a structured outline for a borderless import/export smart contract settled in Pi (π), given the deal terms.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "commodity": {
              "type": "string",
              "description": "Goods / commodity being traded."
            },
            "quantity": {
              "type": "string",
              "description": "Quantity with units, e.g. '10,000 MT'."
            },
            "exporter": {
              "type": "string",
              "description": "Exporter name and country."
            },
            "importer": {
              "type": "string",
              "description": "Importer name and country."
            },
            "incoterm": {
              "type": "string",
              "description": "Incoterms 2020 code, e.g. FOB, CIF."
            },
            "priceInPi": {
              "type": "string",
              "description": "Total price expressed in Pi (π)."
            },
            "deliveryWindow": {
              "type": "string",
              "description": "Delivery window / shipment period."
            }
          },
          "required": [
            "commodity",
            "quantity",
            "exporter",
            "importer",
            "incoterm",
            "priceInPi",
            "deliveryWindow"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "trade_tech_ideas",
        "title": "PiTrade feature & trade-tech ideas",
        "description": "Return fresh ideas for how PiTrade could evolve — informed by advances in Pi Network, cross-border trade, and AI.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "topic": {
              "description": "Optional focus area, e.g. 'compliance', 'logistics oracles', 'Pi Network'.",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
